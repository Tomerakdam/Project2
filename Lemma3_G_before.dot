graph "Lemma3 — G (original K5)" {
  layout=circo;
  node [shape=circle, style=filled, fillcolor=lightblue, fontsize=14];

  v1 [label="v1"];
  v2 [label="v2"];
  v3 [label="v3"];
  v4 [label="v4"];
  v5 [label="v5"];

  v1 -- v2 [label="1", color=red, penwidth=3];
  v2 -- v3 [label="1", color=red, penwidth=3];
  v3 -- v4 [label="1", color=red, penwidth=3];
  v4 -- v5 [label="1", color=red, penwidth=3];
  v5 -- v1 [label="1", color=red, penwidth=3];
  v1 -- v3 [label="2", color=red, penwidth=3];
  v2 -- v4 [label="2", color=red, penwidth=3];
  v3 -- v5 [label="2", color=red, penwidth=3];
  v1 -- v4 [label="2", color=red, penwidth=3];
  v2 -- v5 [label="2", color=red, penwidth=3];
}
