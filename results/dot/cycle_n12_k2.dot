  "10" -- "11" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "11" -- "0" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "2" -- "3" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "3" -- "4" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "4" -- "5" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "5" -- "6" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "6" -- "7" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "7" -- "8" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "8" -- "9" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "9" -- "10" [label="1", color="#d62728", style="solid", penwidth=2.6];
}
