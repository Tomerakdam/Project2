graph G {
  graph [layout=neato, overlap=false, splines=true, outputorder=edgesfirst, label="cycle_threshold_n7, k=4, stretch=7, original edges=7, spanner edges=6 | blue=chosen MST in spanner, red=extra spanner, gray dashed=removed", labelloc=t, fontsize=18];
  node [shape=circle, style=filled, fillcolor=white, color="#222222", fontname="Arial", fontsize=11];
  edge [fontname="Arial", fontsize=9];
  "0" [label="0"];
  "1" [label="1"];
  "2" [label="2"];
  "3" [label="3"];
  "4" [label="4"];
  "5" [label="5"];
  "6" [label="6"];
  "0" -- "1" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "1" -- "2" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "2" -- "3" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "3" -- "4" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "4" -- "5" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "5" -- "6" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "6" -- "0" [label="1", color="#aaaaaa", style="dashed", penwidth=1.1];
}
