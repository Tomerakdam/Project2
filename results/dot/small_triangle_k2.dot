graph G {
  graph [layout=neato, overlap=false, splines=true, outputorder=edgesfirst, label="small_triangle, k=2, stretch=3, original edges=3, spanner edges=2 | blue=chosen MST in spanner, red=extra spanner, gray dashed=removed", labelloc=t, fontsize=18];
  node [shape=circle, style=filled, fillcolor=white, color="#222222", fontname="Arial", fontsize=11];
  edge [fontname="Arial", fontsize=9];
  "0" [label="0"];
  "1" [label="1"];
  "2" [label="2"];
  "0" -- "1" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
  "0" -- "2" [label="3", color="#aaaaaa", style="dashed", penwidth=1.1];
  "1" -- "2" [label="1", color="#1f77b4", style="solid", penwidth=3.2];
}
