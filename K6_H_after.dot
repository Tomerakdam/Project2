graph "H = 3-spanner  (AFTER: 5 edges kept, red)" {
  layout=circo;
  overlap=false;
  label="H = 3-spanner  (AFTER: 5 edges kept, red)";
  fontsize=16;
  labelloc=t;

  // vertices
  0 [label="v0", shape=circle, style=filled, fillcolor=lightblue, fontsize=13];
  1 [label="v1", shape=circle, style=filled, fillcolor=lightblue, fontsize=13];
  2 [label="v2", shape=circle, style=filled, fillcolor=lightblue, fontsize=13];
  3 [label="v3", shape=circle, style=filled, fillcolor=lightblue, fontsize=13];
  4 [label="v4", shape=circle, style=filled, fillcolor=lightblue, fontsize=13];
  5 [label="v5", shape=circle, style=filled, fillcolor=lightblue, fontsize=13];

  // edges
  2 -- 4 [label="3", color=red, penwidth=3.0, fontcolor=red, fontsize=11];
  2 -- 5 [label="3", color=red, penwidth=3.0, fontcolor=red, fontsize=11];
  0 -- 2 [label="4", color=red, penwidth=3.0, fontcolor=red, fontsize=11];
  0 -- 4 [label="5", color=grey, style=dashed, penwidth=0.8, fontcolor=grey, fontsize=9];
  1 -- 2 [label="6", color=red, penwidth=3.0, fontcolor=red, fontsize=11];
  1 -- 3 [label="6", color=red, penwidth=3.0, fontcolor=red, fontsize=11];
  0 -- 3 [label="9", color=grey, style=dashed, penwidth=0.8, fontcolor=grey, fontsize=9];
  0 -- 1 [label="11", color=grey, style=dashed, penwidth=0.8, fontcolor=grey, fontsize=9];
  0 -- 5 [label="11", color=grey, style=dashed, penwidth=0.8, fontcolor=grey, fontsize=9];
  3 -- 5 [label="13", color=grey, style=dashed, penwidth=0.8, fontcolor=grey, fontsize=9];
  2 -- 3 [label="14", color=grey, style=dashed, penwidth=0.8, fontcolor=grey, fontsize=9];
  3 -- 4 [label="17", color=grey, style=dashed, penwidth=0.8, fontcolor=grey, fontsize=9];
  4 -- 5 [label="17", color=grey, style=dashed, penwidth=0.8, fontcolor=grey, fontsize=9];
  1 -- 4 [label="19", color=grey, style=dashed, penwidth=0.8, fontcolor=grey, fontsize=9];
  1 -- 5 [label="20", color=grey, style=dashed, penwidth=0.8, fontcolor=grey, fontsize=9];
}
