graph "SmallTriangle — H (spanner)" {
  layout=circo;
  node [shape=circle, style=filled, fillcolor=lightblue, fontsize=14];

  v1 [label="v1"];
  v2 [label="v2"];
  v3 [label="v3"];

  v1 -- v2 [label="1", color=red, penwidth=3];
  v2 -- v3 [label="1", color=red, penwidth=3];
  v1 -- v3 [label="2", color=grey, style=dashed, penwidth=1];
}
